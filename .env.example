# Copy to .env; codebase-analyzer loads it without overriding exported shell variables.
OPENAI_API_KEY=replace-with-your-api-key
CODE_ANALYZER_PROVIDER=openai
CODE_ANALYZER_MODEL=gpt-5.4-mini

# Ollama alternative (do not expose an unauthenticated Ollama port publicly)
# CODE_ANALYZER_PROVIDER=ollama
# CODE_ANALYZER_MODEL=qwen3.5-32k
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_TIMEOUT_SECONDS=7200
# OLLAMA_API_KEY=ollama

# Provider response/read and shared connection timeouts
# OPENAI_TIMEOUT_SECONDS=180
# CONNECT_TIMEOUT_SECONDS=10
